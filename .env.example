# ===== 模型 API Key（至少填一项；默认使用 DeepSeek）=====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash
ZHIPU_EMBED_MODEL=embedding-3

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ===== 默认生成模型 =====
DEFAULT_LLM=deepseek

# ===== 向量库 =====
# 留空 = 纯内存（零依赖，重启需重新入库）；填下面地址则自动切换 Qdrant。
# 本地 Qdrant（Windows 原生 / Docker 均可）：设为本机地址即可，无需改代码。
#   Windows 原生：QDRANT_URL=http://localhost:6333
#   Docker：      docker compose up -d 后同样设为 http://localhost:6333
# 注：未安装 qdrant-client 时会自动走零依赖 REST 适配，照常可用。
QDRANT_URL=
QDRANT_API_KEY=
COLLECTION_NAME=community_mediation

# ===== 服务 =====
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ===== 调试 =====
MOCK=false
