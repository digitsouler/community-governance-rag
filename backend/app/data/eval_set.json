    "version": "1.0",
    "description": "覆盖 retrieve/direct/clarify/out_of_domain 四类路由的评测问答对。expected_route 为期望路由；expected_points 为答案应覆盖的关键要点；expected_category 为期望命中的语料分类（仅 retrieve 类有）；is_out_of_domain 标记是否属离域拒答。",
    "route_labels": {
      "retrieve": "走检索并生成",
      "direct": "直接回答（问候/自我介绍类）",
      "clarify": "要求澄清（信息过少）",
      "out_of_domain": "超出服务范围（离域拒答）"
    }
  },
