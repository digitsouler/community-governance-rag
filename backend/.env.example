# 复制本文件为 .env 并填入你的 key（三项至少填一项；默认用 DeepSeek 作为开发基准）
# 不填任何 key 时自动进入 mock 模式，管道仍可跑通（用于本地冒烟）。

MOCK=false

# ---- DeepSeek（开发基准）----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ---- 智谱 GLM（同时承担 Embedding 向量化）----
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash
ZHIPU_EMBED_MODEL=embedding-3

# ---- 通义千问 Qwen ----
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ---- 向量库 ----
# 留空 = 纯内存模式（零依赖，开箱即用）；填入 url 则使用远程 Qdrant（需已装 qdrant-client）
QDRANT_URL=
COLLECTION_NAME=community_mediation
VECTOR_DIM=2048

# ---- 检索 / 自纠错参数 ----
TOP_K=8
RERANK_TOP_K=4
MAX_RETRIEVE_RETRIES=2
RELEVANCE_THRESHOLD=0.15
